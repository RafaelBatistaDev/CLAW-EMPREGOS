<!-- HTML (Permanece igual, apenas certifique-se dos IDs) -->
<div style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;align-items:center;">
    <input type="text" id="filtro-cidade" placeholder="🔍 Cidade..." oninput="filtrarVagas()"
           style="padding:10px; background:#181c2e; border:1px solid #2a2f4a; color:#e8eaf4; border-radius:9px; flex:1; min-width:200px;">

    <label style="color:#7b82a6; font-size:13px;">De:</label>
    <input type="date" id="data-inicio" onchange="filtrarVagas()"
           style="padding:10px; background:#181c2e; border:1px solid #2a2f4a; color:#e8eaf4; border-radius:9px;">

    <label style="color:#7b82a6; font-size:13px;">Até:</label>
    <input type="date" id="data-fim" onchange="filtrarVagas()"
           style="padding:10px; background:#181c2e; border:1px solid #2a2f4a; color:#e8eaf4; border-radius:9px;">

    <button onclick="limparFiltro()"
            style="padding:10px 16px; background:#1e2235; border:1px solid #2a2f4a; color:#7b82a6; border-radius:9px; cursor:pointer;">
        ✕ Limpar
    </button>
</div>

<script>
function filtrarVagas() {
    const cidadeTermo = document.getElementById('filtro-cidade').value.toLowerCase().trim();
    const dataInicio = document.getElementById('data-inicio').value;
    const dataFim = document.getElementById('data-fim').value;

    document.querySelectorAll('.vaga').forEach(vaga => {
        const textoCompleto = vaga.textContent;
        const cidadeVaga = (vaga.dataset.cidade || '').toLowerCase();

        // Extrai a data no formato 0000-00-00 do texto da vaga
        const regexData = /\d{4}-\d{2}-\d{2}/;
        const buscaData = textoCompleto.match(regexData);
        const dataPostagem = buscaData ? buscaData[0] : null;

        // Filtro de Cidade/Localização
        const matchesCidade = !cidadeTermo ||
                              cidadeVaga.includes(cidadeTermo) ||
                              textoCompleto.toLowerCase().includes(cidadeTermo);

        // Filtro de Intervalo de Datas
        let matchesData = true;
        if (dataInicio || dataFim) {
            if (dataPostagem) {
                // Compara strings AAAA-MM-DD (funciona nativamente)
                if (dataInicio && dataPostagem < dataInicio) matchesData = false;
                if (dataFim && dataPostagem > dataFim) matchesData = false;
            } else {
                matchesData = false; // Oculta se não encontrar data na vaga
            }
        }

        vaga.style.display = (matchesCidade && matchesData) ? '' : 'none';
    });

    // Ocultar categorias sem resultados
    document.querySelectorAll('.categoria').forEach(cat => {
        const visiveis = [...cat.querySelectorAll('.vaga')].some(v => v.style.display !== 'none');
        cat.style.display = temVisiveis ? '' : 'none';
    });
}

function limparFiltro() {
    document.getElementById('filtro-cidade').value = '';
    document.getElementById('data-inicio').value = '';
    document.getElementById('data-fim').value = '';
    filtrarVagas();
}
</script>
